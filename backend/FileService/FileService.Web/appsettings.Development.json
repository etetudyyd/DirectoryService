{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Database": "Host=localhost;Port=5432;Database=file_service_db;Username=postgres;Password=postgres",
    "Seq": "http://localhost:5341",
    "Redis": "localhost:6379"
  },
  "S3Options": {
    "Endpoint" : "http://localhost:9000/",
    "AccessKey" : "minioadmin",
    "SecretKey" : "minioadmin",
    "WithSsl" : false,
    "DownloadUrlExpirationHours": 24,
    "UploadUrlExpirationHours": 6,
    "MaxConcurrentRequests": 20,
    "RecommendedChunkSizeBytes": 104857600,
    "MaxChunks": 10000,
    "RequiredBuckets": ["videos", "previews", "documents"]
  },
  "Database": {
    "AutoMigrate": true
  },
  "InactiveDepartmentsCleanerInterval": {
    "IntervalHours": 24
  }
}
